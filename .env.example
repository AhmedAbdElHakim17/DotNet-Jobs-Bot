# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_channel_or_group_id_here

# ── LinkedIn Posts RSS (PRIMARY) ──────────────────────────────────────────────
# rss.app feeds watching LinkedIn FEED POSTS that mention .NET / C# hiring.
# These are social posts by recruiters ("We are hiring a .NET developer!"),
# NOT the LinkedIn Jobs tab — this is what catches early hiring signals fast.
#
# Setup (one feed per LinkedIn search, comma-separate multiple):
#   1. Open LinkedIn and search for:  ".NET developer hiring"
#      URL: https://www.linkedin.com/search/results/content/?keywords=.NET+developer+hiring
#   2. Copy that URL and paste it at https://rss.app -> New Feed -> Generate RSS
#   3. Copy the RSS URL (e.g. https://rss.app/feeds/XXXXXXXXXXXXXXXX.xml)
#
# Suggested feeds to create (one URL per search):
#   - .NET developer hiring Egypt
#   - C# developer hiring Cairo
#   - ASP.NET hiring Gulf
#   - #dotnet #hiring
LINKEDIN_POSTS_RSS_URLS=https://rss.app/feeds/your_posts_feed_1.xml,https://rss.app/feeds/your_posts_feed_2.xml

# ── LinkedIn Jobs RSS (SECONDARY) ─────────────────────────────────────────────
# rss.app feeds watching the LinkedIn Jobs tab search results.
#
# Setup:
#   1. Open LinkedIn Jobs and search for ".NET Developer" + "Egypt" (or any location)
#      URL: https://www.linkedin.com/jobs/search/?keywords=.NET+Developer&location=Egypt
#   2. Paste that URL at https://rss.app -> New Feed -> Generate RSS
#   3. Copy the RSS URL
LINKEDIN_JOBS_RSS_URLS=https://rss.app/feeds/your_jobs_feed_1.xml

# ── LinkedIn Auth (optional — for social post search via unofficial API) ───────
# Cookie auth is more stable than email/password (LinkedIn blocks automated logins).
# Get li_at: linkedin.com -> F12 -> Application -> Cookies -> li_at -> copy Value
LINKEDIN_COOKIE=

# Fallback if no cookie (often blocked by LinkedIn security challenges):
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
