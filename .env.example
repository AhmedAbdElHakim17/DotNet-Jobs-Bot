# --- Required: Telegram ---
TELEGRAM_BOT_TOKEN=your_token_from_botfather
TELEGRAM_CHAT_ID=-1001234567890

# --- LinkedIn job listings (RSS — comma-separated URLs, e.g. rss.app) ---
LINKEDIN_RSS_URLS=https://example.com/your-linkedin-jobs-feed.xml

# --- LinkedIn social posts (trusted early signals; often blocked in CI — optional) ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# --- Region & noise control ---
# Default: only Egypt/Gulf alerts (plus Wuzzuf, LinkedIn posts, your RSS). Set 0 to allow all geos.
STRICT_REGION_FILTER=1
# Remotive + We Work Remotely (global noise). Default off.
ENABLE_REMOTE_BOARDS=0

# --- Optional ---
# JOBSPY_INCLUDE_REMOTE=0
# JOBSPY_RESULTS=25
# WUZZUF_DELAY_SEC=1.5
# BOT_CI_FAST=0
